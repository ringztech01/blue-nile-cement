{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "21st": {
      "type": "remote",
      "url": "https://21st.dev/api/mcp",
      "enabled": true,
      "headers": {
        "x-api-key": "{env:API_KEY_21ST}"
      }
    },
    "openart": {
      "type": "remote",
      "url": "https://mcp.openart.ai/mcp",
      "enabled": true
    }
  }
}
